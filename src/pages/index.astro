---
import { createHash } from "node:crypto";
import { readFileSync } from "node:fs";
import { join } from "node:path";

import NoteArchive from "../components/NoteArchive.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteSidebar from "../components/SiteSidebar.astro";
import { loadNotes } from "../lib/notes";

const notes = await loadNotes();
const base = import.meta.env.BASE_URL;
const stylesheet = readFileSync(join(process.cwd(), "styles/site.css"));
const styleVersion = createHash("sha256").update(stylesheet).digest("hex").slice(0, 12);
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="技術の検証と小さなサービスの構想を残す個人用ノート" />
    <meta name="generator" content={Astro.generator} />
    <title>技術ノート</title>
    <link rel="stylesheet" href={`${base}styles/site.css?v=${styleVersion}`} />
  </head>
  <body id="top">
    <a class="skip-link" href="#notes">ノート一覧へ移動</a>
    <SiteHeader />

    <section class="intro-band">
      <div class="intro-inner">
        <h1>調べたことを、あとで使える形に。</h1>
        <p>{notes.length} notes</p>
      </div>
    </section>

    <main class="content-shell" id="notes">
      <NoteArchive notes={notes} />
      <SiteSidebar notes={notes} />
    </main>

    <footer class="site-footer">
      <p>Shima's technical field notes.</p>
    </footer>
  </body>
</html>
